# ============================================================
# LiveMapEvents — Docker Environment Variables
# ============================================================
# Copy this file: cp .env.docker.example .env.docker
# Then fill in your actual values below.
# ============================================================

APP_NAME=LiveMapEvents
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database (matches docker-compose service names) ──
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=livemap
DB_USERNAME=livemap
DB_PASSWORD=secret

# ── Redis ──
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Session / Cache / Queue ──
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id-here

# ── UltraMsg (WhatsApp OTP) ──
ULTRAMSG_URL=https://api.ultramsg.com
ULTRAMSG_INSTANCE_ID=your-instance-id
ULTRAMSG_TOKEN=your-ultramsg-token

# ── Mail (optional) ──
MAIL_MAILER=log
