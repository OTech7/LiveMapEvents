# ============================================================
# LiveMapEvents — Docker environment template
# ============================================================
# Copy to .env.docker and replace dummy values with real ones.
# This file is committed; .env.docker MUST NOT be committed
# (already in .gitignore).
#
# When deploying via deploy-remote.sh this file is auto-generated
# from server.local.conf — you only need to maintain it by hand
# on the production host (or when running ./deploy.sh standalone).
# ============================================================

# ── Laravel core ──
APP_NAME=LiveMapEvents
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate_OUTPUT
APP_DEBUG=false
APP_URL=https://api.live-events-map.tech
APP_PORT=8080
FRONTEND_PORT=3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database (PostgreSQL + PostGIS) ──
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=livemap
DB_USERNAME=livemap
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_SSLMODE=prefer

# ── Redis ──
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Session / Cache / Queue drivers ──
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id-here

# ── OTP / Phone auth ──
OTP_DRIVER=ultramsg
OTP_TTL=300
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60
OTP_FAKE=false
OTP_FAKE_CODE=000000

ULTRAMSG_URL=https://api.ultramsg.com
ULTRAMSG_INSTANCE_ID=your-instance-id
ULTRAMSG_TOKEN=your-ultramsg-token

# ── Mail ──
MAIL_MAILER=log

# ── Flutter web build-time values (consumed by frontend Dockerfile) ──
FLUTTER_BASE_URL=https://api.live-events-map.tech/api/v1/
FLUTTER_GOOGLE_SERVER_CLIENT_ID=your-google-client-id-here

# ── Caddy (reverse proxy / ACME) ──
# Email Let's Encrypt uses for cert-expiry notices. Required for the
# caddy service to start in production.
ACME_EMAIL=admin@example.com
