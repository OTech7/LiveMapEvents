# ============================================================
# LiveMapEvents — Server Configuration
# ============================================================
# FILL IN YOUR VALUES BELOW, then run:
#   cp server.conf.example server.conf
#   nano server.conf           (edit with your real values)
#   ./deploy-remote.sh         (deploy from your Mac)
# ============================================================

# ── Your Server ──
SERVER_IP=0.0.0.0                          # <-- Your server IP (e.g. 165.22.48.100)
SERVER_HOSTNAME=livemap.example.com        # <-- Your domain, or same as SERVER_IP if no domain
SERVER_USER=deploy                         # <-- SSH user on the server
SERVER_SSH_KEY=~/.ssh/livemap_deploy       # <-- Path to your private SSH key
SERVER_DEPLOY_PATH=/opt/livemap            # <-- Where the app lives on the server

# ── App Settings ──
APP_PORT=8080                              # <-- Port the app listens on (80 if using domain)
APP_ENV=production
APP_DEBUG=false

# ── Database ──
DB_DATABASE=livemap
DB_USERNAME=livemap
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD # <-- Generate with: openssl rand -base64 24

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com  # <-- From Google Cloud Console

# ── UltraMsg (WhatsApp OTP) ──
ULTRAMSG_URL=https://api.ultramsg.com
ULTRAMSG_INSTANCE_ID=your-instance-id      # <-- From ultramsg.com dashboard
ULTRAMSG_TOKEN=your-token                  # <-- From ultramsg.com dashboard
