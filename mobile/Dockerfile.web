# ============================================================
# LiveMapEvents Flutter Web — Multi-stage Docker Build
# ============================================================
# Builds the Flutter mobile app for web and serves via Nginx.
#
# Usage (standalone):
#   docker build -f Dockerfile.web -t livemap-frontend .
#   docker run -p 3000:80 livemap-frontend
# ============================================================

# ---- Stage 1: Flutter Web Build ----
FROM ghcr.io/cirruslabs/flutter:stable AS build

WORKDIR /app

# Copy dependency files first for better caching
COPY pubspec.yaml pubspec.lock* ./

# Get dependencies
RUN flutter pub get

# Copy the rest of the source code
COPY . .

# .env is gitignored but listed as a Flutter asset — create an empty one
# if it wasn't supplied so the asset bundler doesn't abort the build.
# Real runtime values should be baked in via --dart-define or a build arg.
RUN test -f .env || touch .env

# Build for web with release optimizations
# --base-href ensures assets load correctly behind a reverse proxy
# --pwa-strategy=none disables the offline service worker so users always
# get the latest deploy on reload (no stale caches between releases).
# Drop --pwa-strategy=none if you later want true PWA / offline support.
ARG BASE_HREF=/
ARG FLUTTER_BASE_URL=https://api.live-events-map.tech/api/v1/
ARG FLUTTER_GOOGLE_SERVER_CLIENT_ID=
RUN flutter build web --release \
    --base-href "$BASE_HREF" \
    --dart-define=BASE_URL="$FLUTTER_BASE_URL" \
    --dart-define=GOOGLE_SERVER_CLIENT_ID="$FLUTTER_GOOGLE_SERVER_CLIENT_ID" \
    --pwa-strategy=none

# ---- Stage 2: Nginx to serve static files ----
FROM nginx:1.27-alpine AS production

LABEL maintainer="LiveMapEvents Team"
LABEL description="LiveMapEvents Flutter Web Frontend"

# Remove default nginx content
RUN rm -rf /usr/share/nginx/html/*

# Copy built Flutter web app
COPY --from=build /app/build/web /usr/share/nginx/html

# Copy custom nginx config
COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
