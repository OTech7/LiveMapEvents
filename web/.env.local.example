# Copy to .env.local and adjust for your local setup.
#
# NEXT_PUBLIC_API_BASE_URL is the URL the Next.js dev server forwards
# /api/* to. The browser never hits this directly — it talks to
# http://localhost:3000 and Next.js proxies (see next.config.js).
#
# Common values:
#   http://localhost:8000          # `php artisan serve` on the host
#   http://localhost               # docker-compose with Caddy on :80
#   https://api.live-events-map.tech  # talk to the production API

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
